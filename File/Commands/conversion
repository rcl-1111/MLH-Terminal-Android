#!/bin/bash
# Conversion命令 - 多媒体文件转换工具
# 用法: conversion [文件] [类型] [转化后的文件名] [参数1] [参数2] [参数3] ...

# 颜色定义
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
MAGENTA='\033[1;35m'
CYAN='\033[1;36m'
WHITE='\033[1;37m'
BOLD='\033[1m'
NC='\033[0m'

# 符号定义
CHECK="${GREEN}[√]${NC}"
CROSS="${RED}[×]${NC}"
INFO="${YELLOW}[*]${NC}"

# 获取脚本所在目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BASE_DIR="$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")"

# 工具路径
FFMPEG_CMD="ffmpeg"
CONVERT_CMD="convert"  # ImageMagick
SOX_CMD="sox"  # 音频处理

# 获取绝对路径函数
get_absolute_path() {
    local path="$1"
    
    # 如果是空路径
    if [[ -z "$path" ]]; then
        echo ""
        return
    fi
    
    # 如果是绝对路径（以/开头）
    if [[ "$path" == /* ]]; then
        echo "$path"
    else
        # 相对路径，转换为绝对路径
        echo "$(cd "$(dirname "$path")" && pwd)/$(basename "$path")"
    fi
}

# 获取文件所在目录
get_file_directory() {
    local file="$1"
    if [[ -f "$file" ]]; then
        dirname "$file"
    elif [[ -d "$file" ]]; then
        echo "$file"
    else
        # 文件不存在，返回当前目录
        echo "."
    fi
}

# 检查依赖
check_dependencies() {
    local missing_tools=()
    
    # 检查ffmpeg
    if ! command -v $FFMPEG_CMD >/dev/null 2>&1; then
        echo -e "${INFO} 警告: 未找到 ffmpeg"
        echo -e "  请运行: pkg install ffmpeg -y"
        missing_tools+=("ffmpeg")
    fi
    
    # 检查convert (ImageMagick)
    if ! command -v $CONVERT_CMD >/dev/null 2>&1; then
        echo -e "${INFO} 警告: 未找到 ImageMagick (convert)"
        echo -e "  请运行: pkg install imagemagick -y"
        missing_tools+=("imagemagick")
    fi
    
    # 检查sox
    if ! command -v $SOX_CMD >/dev/null 2>&1; then
        echo -e "${INFO} 警告: 未找到 sox"
        echo -e "  请运行: pkg install sox -y"
        missing_tools+=("sox")
    fi
    
    if [[ ${#missing_tools[@]} -gt 0 ]]; then
        echo -e "${CROSS} 错误: 缺少必要的工具"
        return 1
    fi
    
    return 0
}

