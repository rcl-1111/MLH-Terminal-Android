# 获取文件扩展名
get_extension() {
    local filename="$1"
    echo "${filename##*.}"
}

# 获取文件名（不含扩展名和路径）
get_basename() {
    local filename="$1"
    filename=$(basename "$filename")
    echo "${filename%.*}"
}

# 检查文件是否存在
check_file_exists() {
    local file="$1"
    
    if [[ ! -f "$file" ]]; then
        echo -e "${CROSS} 错误: 文件不存在: $file"
        echo -e "${INFO} 请检查:"
        echo -e "  • 文件路径是否正确"
        echo -e "  • 是否使用了正确的相对/绝对路径"
        echo -e "  • 文件是否有读权限"
        return 1
    fi
    
    if [[ ! -r "$file" ]]; then
        echo -e "${CROSS} 错误: 文件不可读: $file"
        echo -e "${INFO} 请检查文件权限"
        return 1
    fi
    
    return 0
}

# 创建输出目录
create_output_dir() {
    local dir="$1"
    
    if [[ ! -d "$dir" ]]; then
        echo -e "${INFO} 创建目录: $dir"
        mkdir -p "$dir"
        if [[ $? -ne 0 ]]; then
            echo -e "${CROSS} 错误: 无法创建目录: $dir"
            echo -e "${INFO} 请检查:"
            echo -e "  • 是否有写权限"
            echo -e "  • 磁盘空间是否足够"
            return 1
        fi
    fi
    
    # 检查目录是否有写权限
    if [[ ! -w "$dir" ]]; then
        echo -e "${CROSS} 错误: 目录不可写: $dir"
        return 1
    fi
    
    return 0
}

# 规范化格式名称（转换为小写）
normalize_format() {
    local format="$1"
    echo "$format" | tr '[:upper:]' '[:lower:]'
}

# 解析输出路径
parse_output_path() {
    local output_name="$1"
    local target_type="$2"
    local output_dir="$3"
    
    # 从输出名称中提取路径和文件名
    local output_basename=$(basename "$output_name")
    local output_parent=$(dirname "$output_name")
    
    # 如果输出名称包含路径，且没有指定-p参数，则使用输出名称中的路径
    if [[ "$output_parent" != "." ]] && [[ -z "$output_dir" ]]; then
        output_dir="$output_parent"
        output_name="$output_basename"
    fi
    
    # 默认输出目录为当前目录
    if [[ -z "$output_dir" ]]; then
        output_dir="."
    fi
    
    # 构建完整的输出文件路径
    local output_file="$output_dir/${output_name}.${target_type}"
    
    echo "$output_dir|$output_name|$output_file"
}

# 获取文件信息
get_file_info() {
    local file="$1"
    
    if [[ ! -f "$file" ]]; then
        echo "文件不存在"
        return
    fi
    
    # 获取文件大小
    local size=$(stat -c%s "$file" 2>/dev/null || stat -f%z "$file" 2>/dev/null || echo "未知")
    local size_display=""
    if [[ "$size" != "未知" ]] && [[ "$size" =~ ^[0-9]+$ ]]; then
        if [[ $size -ge 1073741824 ]]; then
            size_display=$(echo "scale=2; $size/1073741824" | bc)GB
        elif [[ $size -ge 1048576 ]]; then
            size_display=$(echo "scale=2; $size/1048576" | bc)MB
        elif [[ $size -ge 1024 ]]; then
            size_display=$(echo "scale=2; $size/1024" | bc)KB
        else
            size_display="${size}B"
        fi
    else
        size_display="未知"
    fi
    
    # 获取文件类型
    local file_type=$(file -b "$file" 2>/dev/null | cut -d, -f1)
    if [[ -z "$file_type" ]]; then
        file_type="未知"
    fi
    
    echo "大小: $size_display | 类型: $file_type"
}

# MP4转MP3
convert_mp4_to_mp3() {
    local input_file="$1"
    local output_file="$2"
    local quality="${3:-192}"
    local bitrate="${4:-192k}"
    local sample_rate="${5:-44100}"
    local channels="${6:-2}"
    
    echo -e "${INFO} 转换: MP4 -> MP3"
    echo -e "  输入: $input_file"
    echo -e "  输出: $output_file"
    echo -e "  质量: $quality"
    echo -e "  比特率: $bitrate"
    echo -e "  采样率: ${sample_rate}Hz"
    echo -e "  声道: $channels"
    
    $FFMPEG_CMD -i "$input_file" -vn -ar "$sample_rate" -ac "$channels" -ab "$bitrate" -f mp3 "$output_file"
    return $?
}

# MP4转OGG
convert_mp4_to_ogg() {
    local input_file="$1"
    local output_file="$2"
    local quality="${3:-5}"
    local sample_rate="${4:-44100}"
    local channels="${5:-2}"
    
    echo -e "${INFO} 转换: MP4 -> OGG"
    
    $FFMPEG_CMD -i "$input_file" -vn -c:a libvorbis -q:a "$quality" -ar "$sample_rate" -ac "$channels" "$output_file"
    return $?
}

# 主转换函数
main_conversion() {
    local input_file="$1"
    local target_type="$2"
    local output_name="$3"
    local output_dir=""
    local quality=""
    local bitrate=""
    local resolution=""
    local start_time=""
    local duration=""
    local fps="10"
    local width="480"
    local sample_rate="44100"
    local channels="2"
    local codec=""
    local framerate=""
    local delete_original=false
    local extra_options=""
    local verbose=false
    
    # 规范化目标格式
    target_type=$(normalize_format "$target_type")
    
    # 解析额外参数
    shift 3
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            -p)
                if [[ -n "$2" ]]; then
                    output_dir="$2"
                    shift 2
                else
                    echo -e "${CROSS} 错误: -p 参数需要指定路径"
                    return 1
                fi
                ;;
            -q)
                if [[ -n "$2" ]]; then
                    quality="$2"
                    shift 2
                else
                    echo -e "${CROSS} 错误: -q 参数需要指定质量值"
                    return 1
                fi
                ;;
            -b)
                if [[ -n "$2" ]]; then
                    bitrate="$2"
                    shift 2
                else
                    echo -e "${CROSS} 错误: -b 参数需要指定比特率"
                    return 1
                fi
                ;;
            -r)
                if [[ -n "$2" ]]; then
                    resolution="$2"
                    shift 2
                else
                    echo -e "${CROSS} 错误: -r 参数需要指定分辨率"
                    return 1
                fi
                ;;
            -s)
                if [[ -n "$2" ]]; then
                    start_time="$2"
                    shift 2
                else
                    echo -e "${CROSS} 错误: -s 参数需要指定开始时间"
                    return 1
                fi
                ;;
            -t)
                if [[ -n "$2" ]]; then
                    duration="$2"
                    shift 2
                else
                    echo -e "${CROSS} 错误: -t 参数需要指定时长"
                    return 1
                fi
                ;;
            -c)
                if [[ -n "$2" ]]; then
                    codec="$2"
                    shift 2
                else
                    echo -e "${CROSS} 错误: -c 参数需要指定编解码器"
                    return 1
                fi
                ;;
            -f)
                if [[ -n "$2" ]]; then
                    framerate="$2"
                    shift 2
                else
                    echo -e "${CROSS} 错误: -f 参数需要指定帧率"
                    return 1
                fi
                ;;
            -a)
                if [[ -n "$2" ]]; then
                    sample_rate="$2"
                    shift 2
                else
                    echo -e "${CROSS} 错误: -a 参数需要指定采样率"
                    return 1
                fi
                ;;
            -v)
                if [[ -n "$2" ]]; then
                    channels="$2"
                    shift 2
                else
                    echo -e "${CROSS} 错误: -v 参数需要指定声道数"
                    return 1
                fi
                ;;
            -d)
                delete_original=true
                shift
                ;;
            -o)
                if [[ -n "$2" ]]; then
                    extra_options="$2"
                    shift 2
                else
                    echo -e "${CROSS} 错误: -o 参数需要指定选项"
                    return 1
                fi
                ;;
            --verbose)
                verbose=true
                shift
                ;;
            -*)
                echo -e "${CROSS} 错误: 未知参数: $1"
                return 1
                ;;
            *)
                shift
                ;;
        esac
    done
    
    # 检查输入文件
    if ! check_file_exists "$input_file"; then
        return 1
    fi
    
    # 获取输入文件的绝对路径
    local input_abs_path=$(get_absolute_path "$input_file")
    echo -e "${INFO} 输入文件: $input_abs_path"
    echo -e "${INFO} 文件信息: $(get_file_info "$input_abs_path")"
    
    # 解析输出路径
    local path_info=$(parse_output_path "$output_name" "$target_type" "$output_dir")
    local output_dir=$(echo "$path_info" | cut -d'|' -f1)
    local output_basename=$(echo "$path_info" | cut -d'|' -f2)
    local output_file=$(echo "$path_info" | cut -d'|' -f3)
    
    # 创建输出目录
    if ! create_output_dir "$output_dir"; then
        return 1
    fi
    
    # 获取输出文件的绝对路径
    local output_abs_path=$(get_absolute_path "$output_file")
    
    # 如果输出文件已存在，询问是否覆盖
    if [[ -f "$output_abs_path" ]]; then
        echo -e "${INFO} 警告: 输出文件已存在: $output_abs_path"
        read -p "是否覆盖? [y/N]: " answer
        if [[ ! "$answer" =~ ^[Yy]$ ]]; then
            echo -e "${INFO} 取消转换"
            return 0
        fi
    fi
    
    # 获取输入文件类型
    local input_type=$(get_extension "$input_abs_path")
    input_type=$(normalize_format "$input_type")
    
    echo -e "${INFO} 输出文件: $output_abs_path"
    echo -e "${INFO} 转换格式: ${input_type} -> ${target_type}"
    
    # 根据目标类型选择转换函数
    case "$target_type" in
        # 音频格式
        mp3)
            if [[ "$input_type" == "mp4" ]]; then
                convert_mp4_to_mp3 "$input_abs_path" "$output_abs_path" "$quality" "$bitrate" "$sample_rate" "$channels"
            else
                $FFMPEG_CMD -i "$input_abs_path" -vn -c:a mp3 -b:a "${bitrate:-192k}" -ar "$sample_rate" -ac "$channels" "$output_abs_path"
            fi
            ;;
        ogg)
            if [[ "$input_type" == "mp4" ]]; then
                convert_mp4_to_ogg "$input_abs_path" "$output_abs_path" "${quality:-5}" "$sample_rate" "$channels"
            else
                $FFMPEG_CMD -i "$input_abs_path" -vn -c:a libvorbis -q:a "${quality:-5}" -ar "$sample_rate" -ac "$channels" "$output_abs_path"
            fi
            ;;
        wav)
            $FFMPEG_CMD -i "$input_abs_path" -vn -acodec pcm_s16le -ar "$sample_rate" -ac "$channels" "$output_abs_path"
            ;;
        flac)
            $FFMPEG_CMD -i "$input_abs_path" -vn -c:a flac -compression_level "${quality:-5}" -ar "$sample_rate" -ac "$channels" "$output_abs_path"
            ;;
        aac)
            $FFMPEG_CMD -i "$input_abs_path" -vn -c:a aac -b:a "${bitrate:-192k}" -ar "$sample_rate" -ac "$channels" -strict experimental "$output_abs_path"
            ;;
        m4a)
            $FFMPEG_CMD -i "$input_abs_path" -vn -c:a aac -b:a "${bitrate:-192k}" -ar "$sample_rate" -ac "$channels" "$output_abs_path"
            ;;
        mp4|avi|mkv|mov|webm|flv|wmv|3gp)
            # 视频转换
            echo -e "${INFO} 视频转换: ${input_type} -> $target_type"
            local ffmpeg_cmd="$FFMPEG_CMD -i \"$input_abs_path\""
            
            # 设置视频编码器
            if [[ -n "$codec" ]]; then
                ffmpeg_cmd+=" -c:v $codec"
            elif [[ "$target_type" == "mp4" ]]; then
                ffmpeg_cmd+=" -c:v libx264"
            fi
            
            # 设置分辨率
            if [[ -n "$resolution" ]]; then
                ffmpeg_cmd+=" -s $resolution"
            fi
            
            # 设置比特率
            if [[ -n "$bitrate" ]]; then
                ffmpeg_cmd+=" -b:v $bitrate"
            fi
            
            # 设置帧率
            if [[ -n "$framerate" ]]; then
                ffmpeg_cmd+=" -r $framerate"
            fi
            
            # 设置质量参数
            if [[ "$target_type" == "mp4" ]] || [[ "$target_type" == "mkv" ]] || [[ "$target_type" == "mov" ]]; then
                ffmpeg_cmd+=" -crf ${quality:-23} -preset medium -c:a aac -b:a 128k"
            elif [[ "$target_type" == "avi" ]]; then
                ffmpeg_cmd+=" -q:v ${quality:-5} -c:a mp3 -b:a 128k"
            elif [[ "$target_type" == "webm" ]]; then
                ffmpeg_cmd+=" -crf ${quality:-10} -b:v 1M -c:a libvorbis"
            fi
            
            ffmpeg_cmd+=" \"$output_abs_path\""
            
            echo -e "  命令: $ffmpeg_cmd"
            eval "$ffmpeg_cmd"
            ;;
        jpg|jpeg|png|webp|bmp|ico|tiff|tif|gif)
            # 图片转换
            echo -e "${INFO} 图片转换: ${input_type} -> $target_type"
            if command -v $CONVERT_CMD >/dev/null 2>&1; then
                local convert_cmd="$CONVERT_CMD \"$input_abs_path\""
                if [[ -n "$resolution" ]]; then
                    convert_cmd+=" -resize $resolution"
                fi
                convert_cmd+=" -quality ${quality:-90} \"$output_abs_path\""
                echo -e "  命令: $convert_cmd"
                eval "$convert_cmd"
            else
                echo -e "${CROSS} 错误: 需要安装 ImageMagick (convert)"
                return 1
            fi
            ;;
        pdf)
            # PDF转换
            echo -e "${INFO} 转换为PDF"
            if command -v convert >/dev/null 2>&1; then
                convert "$input_abs_path" -quality "${quality:-90}" "$output_abs_path"
            else
                echo -e "${CROSS} 错误: 需要安装 ImageMagick 来转换PDF"
                return 1
            fi
            ;;
        *)
            echo -e "${CROSS} 错误: 不支持的转换类型: $target_type"
            echo -e "使用 'conversion --list-formats' 查看支持的格式"
            return 1
            ;;
    esac
    
    local result=$?
    
    if [[ $result -eq 0 ]]; then
        echo -e "${CHECK} 转换成功!"
        echo -e "${INFO} 输出文件: $output_abs_path"
        echo -e "${INFO} 输出文件信息: $(get_file_info "$output_abs_path")"
        
        # 删除原始文件
        if [[ "$delete_original" == true ]]; then
            echo -e "${INFO} 删除原始文件: $input_abs_path"
            rm -f "$input_abs_path"
        fi
    else
        echo -e "${CROSS} 转换失败!"
        echo -e "${INFO} 可能的原因:"
        echo -e "  • 输入文件格式不支持"
        echo -e "  • 输出路径无写权限"
        echo -e "  • 磁盘空间不足"
        echo -e "  • 编解码器不支持"
    fi
    
    return $result
}

# 主函数
main() {
    # 检查参数
    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi
    
    # 处理特殊参数
    case "$1" in
        --help|-h)
            show_help
            exit 0
            ;;
        --list-formats)
            list_formats
            exit 0
            ;;
    esac
    
    # 检查依赖
    if ! check_dependencies; then
        echo -e "${INFO} 注意: 部分功能可能受限"
        echo -e "您可以选择继续，但某些转换可能无法正常工作"
        read -p "是否继续? [y/N]: " answer
        if [[ ! "$answer" =~ ^[Yy]$ ]]; then
            exit 1
        fi
    fi
    
    # 检查参数数量
    if [[ $# -lt 3 ]]; then
        echo -e "${CROSS} 错误: 参数不足"
        echo -e "用法: conversion [文件] [类型] [转化后的文件名] [参数]"
        echo -e "使用 'conversion --help' 查看详细用法"
        exit 1
    fi
    
    # 执行转换
    main_conversion "$@"
    exit $?
}

# 运行主函数
main "$@"
