#!/bin/bash
# WNAD - Wireless Network Attack and Defense
# MLH-Terminal 无线网络攻防工具入口脚本
# 用法: wnad <命令> [参数]

WNAD_DIR="$(cd "$(dirname "$0")" && pwd)"
WNAD_PY="$WNAD_DIR/wnad.py"

# 检查 Python
PYTHON_CMD=""
for cmd in python3 python; do
    if command -v "$cmd" >/dev/null 2>&1; then
        PYTHON_CMD="$cmd"
        break
    fi
done

if [ -z "$PYTHON_CMD" ]; then
    echo -e "\033[1;31m[!]\033[0m 错误: 未找到 Python 解释器"
    echo -e "\033[1;33m[*]\033[0m 请先安装 Python: pkg install python"
    exit 1
fi

# 执行主程序
exec "$PYTHON_CMD" "$WNAD_PY" "$@"
