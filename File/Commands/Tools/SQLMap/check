#!/bin/bash
# SQLMap 检查脚本
# 版本: 1.0.0

# 加载配置
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/config"

echo "================================================"
echo "        MLH-Terminal SQLMap 状态检查        "
echo "================================================"
echo "检查时间: $(date '+%Y-%m-%d %H:%M:%S')"
echo ""

# 检查安装标记
if [[ -f "$INSTALL_MARKER" ]]; then
    echo "已安装"
    echo "安装信息:"
    cat "$INSTALL_MARKER" 2>/dev/null
else
    echo "未安装"
fi

echo ""

# 检查目录
if [[ -d "$SQLMAP_DIR" ]]; then
    echo "目录存在: $SQLMAP_DIR"
    
    # 检查主文件
    if [[ -f "$SQLMAP_MAIN" ]]; then
        echo "主文件存在: $(basename "$SQLMAP_MAIN")"
        
        # 测试版本
        cd "$SQLMAP_DIR"
        VERSION=$(python "$SQLMAP_MAIN" --version 2>/dev/null | head -1 || echo "未知")
        echo "当前版本: $VERSION"
    else
        echo "主文件不存在"
    fi
else
    echo "目录不存在"
fi

echo ""
echo "================================================"
echo "        检查完成        "
echo "================================================"
