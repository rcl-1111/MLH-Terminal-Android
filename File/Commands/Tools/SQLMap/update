#!/bin/bash
# SQLMap 更新脚本
# 版本: 1.0.0

# 加载配置
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/config"

echo "================================================"
echo "        更新 MLH-Terminal SQLMap 工具        "
echo "================================================"
echo "更新时间: $(date '+%Y-%m-%d %H:%M:%S')"
echo "更新目录: $SQLMAP_DIR"
echo "================================================"
echo ""

# 检查是否安装
if [[ ! -f "$INSTALL_MARKER" ]]; then
    echo "SQLMap 未安装"
    echo "请先运行安装: sqlmap-install"
    exit 1
fi

# 进入 SQLMap 目录
cd "$SQLMAP_DIR" || {
    echo "无法进入 SQLMap 目录"
    exit 1
}

echo "拉取最新代码..."
git pull origin "$GIT_BRANCH"

if [[ $? -eq 0 ]]; then
    # 获取新版本
    NEW_VERSION=$(python "$SQLMAP_MAIN" --version 2>/dev/null | head -1 || echo "未知")
    echo "$NEW_VERSION" > "$VERSION_FILE"
    
    # 更新安装标记
    date > "$INSTALL_MARKER"
    echo "最后更新: $(date '+%Y-%m-%d %H:%M:%S')" >> "$INSTALL_MARKER"
    echo "当前版本: $NEW_VERSION" >> "$INSTALL_MARKER"
    
    echo ""
    echo "更新完成!"
    echo "当前版本: $NEW_VERSION"
else
    echo "更新失败"
    exit 1
fi

echo "================================================"
