# 检查文件是否包含BOM（字节顺序标记）
has_bom() {
    local file="$1"
    if [[ -f "$file" ]]; then
        if head -c 3 "$file" 2>/dev/null | od -An -t x1 | grep -q "ef bb bf"; then
            return 0
        fi
    fi
    return 1
}

# 获取文件的最后几行
get_tail_lines() {
    local file="$1"
    local lines="${2:-10}"
    
    if [[ -f "$file" ]]; then
        if command -v tail >/dev/null 2>&1; then
            tail -n "$lines" "$file" 2>/dev/null || echo "读取失败"
        else
            echo "tail命令未安装"
        fi
    else
        echo "文件不存在"
    fi
}

