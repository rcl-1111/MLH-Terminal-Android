# 检查文件是否可执行（改进版）
is_executable() {
    local file="$1"
    
    if [[ ! -f "$file" ]]; then
        return 1
    fi
    
    # 方法1: 检查文件是否具有可执行权限
    if [[ -x "$file" ]]; then
        return 0
    fi
    
    # 方法2: 检查文件类型
    local file_type=$(get_file_type "$file" 2>/dev/null)
    
    if [[ -n "$file_type" ]]; then
        # Windows可执行文件
        if [[ "$file_type" == *"PE32"* ]] || \
           [[ "$file_type" == *"MS-DOS"* ]] || \
           [[ "$file_type" == *"executable"* ]] || \
           [[ "$file_type" == *"Windows"* ]]; then
            return 0
        fi
        
        # Linux可执行文件
        if [[ "$file_type" == *"ELF"* ]] || \
           [[ "$file_type" == *"shared object"* ]]; then
            return 0
        fi
        
        # Shell脚本
        if [[ "$file_type" == *"shell script"* ]] || \
           [[ "$file_type" == *"Bourne-Again"* ]]; then
            return 0
        fi
        
        # macOS可执行文件
        if [[ "$file_type" == *"Mach-O"* ]]; then
            return 0
        fi
    fi
    
    # 方法3: 检查文件扩展名
    local extension="${file##*.}"
    extension=$(echo "$extension" | tr '[:upper:]' '[:lower:]')
    
    # 可执行文件扩展名列表
    local exec_extensions=(
        "exe" "com" "bat" "cmd" "msi" "app" "dmg" "pkg" "deb" "rpm"
        "bin" "run" "out" "so" "dll" "sys" "ocx" "cpl" "drv" "sh"
        "bash" "zsh" "py" "pl" "rb" "php" "jar" "apk" "ipa" "vbs"
        "js" "ps1" "psm1" "scr" "cpl" "ocx" "sys" "drv" "efi" "ko"
    )
    
    for ext in "${exec_extensions[@]}"; do
        if [[ "$extension" == "$ext" ]]; then
            return 0
        fi
    done
    
    return 1
}

