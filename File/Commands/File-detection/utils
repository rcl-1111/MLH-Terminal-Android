# 计算文件的熵值
calculate_entropy() {
    local file="$1"
    if [[ ! -f "$file" ]]; then
        echo "文件不存在"
        return
    fi
    
    if command -v ent >/dev/null 2>&1; then
        ent "$file" 2>/dev/null | grep -i "entropy" | head -1 || echo "计算失败"
    else
        echo "ent命令未安装"
    fi
}

# 检查文件是否被加壳/混淆
check_packed() {
    local file="$1"
    if [[ ! -f "$file" ]]; then
        return 1
    fi
    
    # 检查常见的加壳/混淆迹象
    local packed_indicators=0
    
    # 检查文件头
    local file_header=$(head -c 100 "$file" 2>/dev/null | xxd 2>/dev/null | head -5)
    
    # 常见的加壳文件头
    local packer_headers=(
        "UPX"      # UPX加壳
        "ASPack"   # ASPack加壳
        "PECompact" # PECompact加壳
        "Themida"  # Themida加壳
        "VMProtect" # VMProtect加壳
    )
    
    for header in "${packer_headers[@]}"; do
        if echo "$file_header" | grep -qi "$header"; then
            echo -e "${WARN} 检测到加壳: $header"
            packed_indicators=$((packed_indicators + 1))
        fi
    done
    
    if [[ $packed_indicators -gt 0 ]]; then
        return 0
    else
        return 1
    fi
}

# 获取文件的数字签名信息
get_digital_signature() {
    local file="$1"
    if [[ ! -f "$file" ]]; then
        echo "文件不存在"
        return
    fi
    
    # 检查Windows PE文件的数字签名
    if [[ "$file" =~ \.(exe|dll|sys|ocx|cpl|drv)$ ]]; then
        if command -v osslsigncode >/dev/null 2>&1; then
            osslsigncode verify "$file" 2>/dev/null | head -20
        else
            echo "osslsigncode未安装，无法检查数字签名"
        fi
    else
        echo "非Windows可执行文件，不检查数字签名"
    fi
}

# 检查文件是否被感染
check_infected() {
    local file="$1"
    local infection_indicators=0
    
    if [[ ! -f "$file" ]]; then
        return 1
    fi
    
    # 检查常见的感染迹象
    echo -e "${INFO} 检查感染迹象..."
    
    # 1. 检查文件大小异常
    local file_size=$(stat -c%s "$file" 2>/dev/null || echo 0)
    local file_type=$(get_file_type "$file")
    
    if [[ "$file_type" == *"ELF"* ]] && [[ $file_size -lt 1024 ]]; then
        echo -e "${WARN} ELF文件过小，可能异常"
        infection_indicators=$((infection_indicators + 1))
    fi
    
    if [[ "$file_type" == *"PE32"* ]] && [[ $file_size -lt 1024 ]]; then
        echo -e "${WARN} PE文件过小，可能异常"
        infection_indicators=$((infection_indicators + 1))
    fi
    
    # 2. 检查文件节区异常
    if [[ "$file" =~ \.(exe|dll)$ ]]; then
        if command -v readelf >/dev/null 2>&1; then
            local section_count=$(readelf -S "$file" 2>/dev/null | grep -c "\[\s*[0-9]\+\]")
            if [[ $section_count -gt 20 ]]; then
                echo -e "${WARN} 文件节区过多 ($section_count 个)"
                infection_indicators=$((infection_indicators + 1))
            fi
        fi
    fi
    
    # 3. 检查导入表异常
    if [[ "$file" =~ \.(exe|dll)$ ]]; then
        if command -v objdump >/dev/null 2>&1; then
            local import_count=$(objdump -p "$file" 2>/dev/null | grep -c "DLL Name:")
            if [[ $import_count -gt 50 ]]; then
                echo -e "${WARN} 导入DLL过多 ($import_count 个)"
                infection_indicators=$((infection_indicators + 1))
            fi
        fi
    fi
    
    if [[ $infection_indicators -gt 0 ]]; then
        echo -e "${WARN} 发现 $infection_indicators 个感染迹象"
        return 1
    else
        echo -e "${CHECK} 未发现感染迹象"
        return 0
    fi
}

# 获取文件的详细安全分析
get_security_analysis() {
    local file="$1"
    
    if [[ ! -f "$file" ]]; then
        echo -e "${CROSS} 文件不存在: $file"
        return 1
    fi
    
    echo -e "${CYAN}文件安全分析: $file${NC}"
    echo -e "${BOLD}┌────────────────────────────────────────────────────────┐${NC}"
    
    # 基本信息
    echo -e "${INFO} 文件路径: $file"
    echo -e "${INFO} 文件大小: $(get_file_size "$file")"
    echo -e "${INFO} 文件类型: $(get_file_type "$file")"
    echo -e "${INFO} 文件权限: $(get_file_permissions "$file")"
    
    # 可执行检查
    if is_executable "$file"; then
        echo -e "${GREEN}[√] 是可执行文件${NC}"
    else
        echo -e "${YELLOW}[!] 不是可执行文件${NC}"
    fi
    
    # 压缩检查
    if is_compressed "$file"; then
        echo -e "${INFO} 压缩文件: 是"
    fi
    
    # 加壳检查
    if check_packed "$file"; then
        echo -e "${YELLOW}[!] 加壳/混淆: 是"
    else
        echo -e "${INFO} 加壳/混淆: 否"
    fi
    
    # 感染检查
    if ! check_infected "$file"; then
        echo -e "${YELLOW}[!] 感染迹象: 发现异常"
    else
        echo -e "${INFO} 感染迹象: 未发现"
    fi
    
    # 数字签名
    local signature_info=$(get_digital_signature "$file")
    if [[ -n "$signature_info" ]] && [[ "$signature_info" != "非Windows可执行文件，不检查数字签名" ]]; then
        echo -e "${INFO} 数字签名: 是"
    else
        echo -e "${INFO} 数字签名: 无"
    fi
    
    # 熵值
    local entropy=$(calculate_entropy "$file")
    if [[ -n "$entropy" ]] && [[ "$entropy" != "计算失败" ]] && [[ "$entropy" != "ent命令未安装" ]]; then
        echo -e "${INFO} 熵值: $entropy"
    fi
    
    echo -e "${BOLD}└────────────────────────────────────────────────────────┘${NC}"
    
    return 0
}

# 记录日志
log_message() {
    local level="$1"
    local message="$2"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    local log_file="$LOG_DIR/file-detection.log"
    
    mkdir -p "$LOG_DIR"
    echo "[$timestamp] [$level] $message" >> "$log_file"
}

# 创建必要的目录结构
create_directories() {
    echo -e "${INFO} 创建必要的目录..."
    
    mkdir -p "$VIRUS_LIB_DIR"
    mkdir -p "$DATA_DIR"
    mkdir -p "$CACHE_DIR"
    mkdir -p "$LOG_DIR"
    
    # 创建平台目录
    for platform in Android Linux Windows MacOS Other; do
        mkdir -p "$VIRUS_LIB_DIR/$platform"
    done
    
    echo -e "${CHECK} 目录创建完成"
}

# 检查文件完整性
check_file_integrity() {
    local file="$1"
    
    if [[ ! -f "$file" ]]; then
        echo -e "${CROSS} 文件不存在: $file"
        return 1
    fi
    
    echo -e "${CYAN}文件完整性检查: $file${NC}"
    echo -e "${BOLD}┌────────────────────────────────────────────────────────┐${NC}"
    
    # 1. 检查文件大小
    local file_size=$(stat -c%s "$file" 2>/dev/null || echo 0)
    echo -e "${INFO} 文件大小: $(get_file_size "$file")"
    
    if [[ $file_size -eq 0 ]]; then
        echo -e "${CROSS} 文件为空"
    else
        echo -e "${CHECK} 文件非空"
    fi
    
    # 2. 检查文件是否损坏
    echo -e "${INFO} 检查文件完整性..."
    
    if is_text "$file"; then
        echo -e "${INFO} 文本文件，检查行尾..."
        local line_endings=$(file "$file" 2>/dev/null | grep -o "with CRLF\|with LF\|with CR")
        if [[ -n "$line_endings" ]]; then
            echo -e "${INFO} 行尾格式: $line_endings"
        fi
    elif is_binary "$file"; then
        echo -e "${INFO} 二进制文件，检查文件头..."
        
        # 检查常见文件类型
        local header=$(head -c 4 "$file" 2>/dev/null | xxd 2>/dev/null | head -1)
        if [[ -n "$header" ]]; then
            echo -e "${INFO} 文件头: $header"
            
            # Windows PE文件
            if echo "$header" | grep -q "4d5a"; then
                echo -e "${GREEN}[√] Windows PE文件签名 (MZ)${NC}"
            fi
            
            # Linux ELF文件
            if echo "$header" | grep -q "7f454c46"; then
                echo -e "${GREEN}[√] Linux ELF文件签名${NC}"
            fi
        fi
    fi
    
    # 3. 检查文件权限
    echo -e "${INFO} 文件权限: $(get_file_permissions "$file")"
    
    # 4. 检查是否有损坏迹象
    echo -e "${INFO} 检查损坏迹象..."
    local file_type=$(get_file_type "$file")
    
    if [[ "$file_type" == *"data"* ]] || [[ "$file_type" == *"corrupt"* ]] || [[ "$file_type" == *"损坏"* ]]; then
        echo -e "${CROSS} 文件可能已损坏"
    else
        echo -e "${CHECK} 文件似乎完整"
    fi
    
    echo -e "${BOLD}└────────────────────────────────────────────────────────┘${NC}"
    
    return 0
}

# 检查文件是否为PE文件
is_pe_file() {
    local file="$1"
    
    if [[ ! -f "$file" ]]; then
        return 1
    fi
    
    # 检查MZ头部
    if head -c 2 "$file" 2>/dev/null | xxd 2>/dev/null | grep -q "4d5a"; then
        return 0
    fi
    
    # 检查文件类型
    local file_type=$(get_file_type "$file")
    if [[ "$file_type" == *"PE32"* ]] || [[ "$file_type" == *"MS-DOS"* ]]; then
        return 0
    fi
    
    return 1
}

# 检查文件是否为ELF文件
is_elf_file() {
    local file="$1"
    
    if [[ ! -f "$file" ]]; then
        return 1
    fi
    
    # 检查ELF头部
    if head -c 4 "$file" 2>/dev/null | xxd 2>/dev/null | grep -q "7f454c46"; then
        return 0
    fi
    
    # 检查文件类型
    local file_type=$(get_file_type "$file")
    if [[ "$file_type" == *"ELF"* ]]; then
        return 0
    fi
    
    return 1
}

# 获取PE文件信息
get_pe_info() {
    local file="$1"
    
    if [[ ! -f "$file" ]]; then
        echo "文件不存在"
        return
    fi
    
    if ! is_pe_file "$file"; then
        echo "不是PE文件"
        return
    fi
    
    echo -e "${CYAN}PE文件信息: $file${NC}"
    echo -e "${BOLD}┌────────────────────────────────────────────────────────┐${NC}"
    
    if command -v objdump >/dev/null 2>&1; then
        # 获取PE文件头信息
        objdump -f "$file" 2>/dev/null | head -20
    else
        echo "objdump命令未安装"
    fi
    
    echo -e "${BOLD}└────────────────────────────────────────────────────────┘${NC}"
}

# 获取ELF文件信息
get_elf_info() {
    local file="$1"
    
    if [[ ! -f "$file" ]]; then
        echo "文件不存在"
        return
    fi
    
    if ! is_elf_file "$file"; then
        echo "不是ELF文件"
        return
    fi
    
    echo -e "${CYAN}ELF文件信息: $file${NC}"
    echo -e "${BOLD}┌────────────────────────────────────────────────────────┐${NC}"
    
    if command -v readelf >/dev/null 2>&1; then
        # 获取ELF文件头信息
        readelf -h "$file" 2>/dev/null
    else
        echo "readelf命令未安装"
    fi
    
    echo -e "${BOLD}└────────────────────────────────────────────────────────┘${NC}"
}
