#!/bin/bash
# File-detection工具函数模块

source "$(dirname "$0")/config"

# 检查网络连接
check_network() {
    echo -e "${INFO} 检查网络连接..."
    if ping -c 1 -W 2 8.8.8.8 >/dev/null 2>&1; then
        echo -e "${CHECK} 网络连接正常"
        return 0
    fi
    
    if curl -s --connect-timeout 3 https://github.com >/dev/null 2>&1; then
        echo -e "${CHECK} 网络连接正常"
        return 0
    fi
    
    echo -e "${CROSS} 网络连接失败"
    return 1
}

# 下载文件
download_file() {
    local url="$1"
    local output="$2"
    
    echo -e "${INFO} 正在下载: $url"
    
    if curl -s -L -o "$output" "$url"; then
        if [[ -s "$output" ]]; then
            echo -e "${CHECK} 下载完成: $(basename "$output")"
            return 0
        else
            echo -e "${CROSS} 下载的文件为空"
            rm -f "$output" 2>/dev/null
            return 1
        fi
    else
        echo -e "${CROSS} 下载失败: $url"
        return 1
    fi
}

# 获取文件创建时间（修复版）
get_creation_time() {
    local file="$1"
    if [[ ! -f "$file" ]]; then
        echo "文件不存在"
        return
    fi
    
    # 尝试多种方法获取创建时间
    local create_time=""
    
    # 方法1: 使用stat命令
    if command -v stat >/dev/null 2>&1; then
        create_time=$(stat -c %w "$file" 2>/dev/null | cut -d. -f1 2>/dev/null)
        
        # 检查stat输出是否有效
        if [[ -n "$create_time" ]] && [[ "$create_time" != "-" ]] && [[ "$create_time" != "?" ]]; then
            echo "$create_time"
            return
        fi
    fi
    
    # 方法2: 尝试使用ls命令
    if command -v ls >/dev/null 2>&1; then
        create_time=$(ls -l --time=birth --time-style=full-iso "$file" 2>/dev/null 2>&1 | awk '{print $6" "$7}' 2>/dev/null | cut -d. -f1 2>/dev/null)
        
        if [[ -n "$create_time" ]] && [[ "$create_time" != "-" ]]; then
            echo "$create_time"
            return
        fi
    fi
    
    # 方法3: 在Android/Termux中，创建时间可能无法获取，返回修改时间
    if command -v stat >/dev/null 2>&1; then
        create_time=$(stat -c %y "$file" 2>/dev/null | cut -d. -f1 2>/dev/null)
        if [[ -n "$create_time" ]]; then
            echo "$create_time (修改时间)"
        else
            echo "无法获取"
        fi
    else
        echo "无法获取"
    fi
}


