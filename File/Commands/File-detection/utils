is_text() {
    local file="$1"
    if [[ -f "$file" ]]; then
        if file "$file" 2>/dev/null | grep -qi "text"; then
            return 0
        fi
    fi
    return 1
}

# 获取文件的字符编码
get_file_encoding() {
    local file="$1"
    if [[ -f "$file" ]]; then
        if command -v file >/dev/null 2>&1; then
            file -i "$file" 2>/dev/null | grep -o "charset=[^;]*" | cut -d= -f2 || echo "未知"
        else
            echo "file命令未安装"
        fi
    else
        echo "文件不存在"
    fi
}

# 获取文件的行数
get_line_count() {
    local file="$1"
    if [[ -f "$file" ]]; then
        if command -v wc >/dev/null 2>&1; then
            wc -l "$file" 2>/dev/null | awk '{print $1}' || echo "计算失败"
        else
            echo "wc命令未安装"
        fi
    else
        echo "文件不存在"
    fi
}

