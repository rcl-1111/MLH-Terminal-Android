# 获取文件占用的磁盘大小
get_disk_usage() {
    local file="$1"
    if [[ -f "$file" ]]; then
        local blocks=$(get_block_count "$file")
        local block_size=$(get_block_size "$file")
        
        if [[ "$blocks" != "未知" ]] && [[ "$block_size" != "未知" ]]; then
            local usage=$((blocks * block_size))
            if [[ $usage -ge 1073741824 ]]; then
                echo "$(echo "scale=2; $usage/1073741824" | bc 2>/dev/null || echo "?") GB"
            elif [[ $usage -ge 1048576 ]]; then
                echo "$(echo "scale=2; $usage/1048576" | bc 2>/dev/null || echo "?") MB"
            elif [[ $usage -ge 1024 ]]; then
                echo "$(echo "scale=2; $usage/1024" | bc 2>/dev/null || echo "?") KB"
            else
                echo "${usage} B"
            fi
        else
            echo "未知"
        fi
    else
        echo "文件不存在"
    fi
}

