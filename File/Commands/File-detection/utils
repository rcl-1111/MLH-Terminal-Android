# 获取文件大小（人类可读）
get_file_size() {
    local file="$1"
    if [[ -f "$file" ]]; then
        if command -v stat >/dev/null 2>&1; then
            local size=$(stat -c%s "$file" 2>/dev/null || echo 0)
            
            if [[ $size -ge 1073741824 ]]; then
                # GB
                echo "$(echo "scale=2; $size/1073741824" | bc 2>/dev/null || echo "?") GB"
            elif [[ $size -ge 1048576 ]]; then
                # MB
                echo "$(echo "scale=2; $size/1048576" | bc 2>/dev/null || echo "?") MB"
            elif [[ $size -ge 1024 ]]; then
                # KB
                echo "$(echo "scale=2; $size/1024" | bc 2>/dev/null || echo "?") KB"
            else
                # Bytes
                echo "${size} B"
            fi
        else
            echo "stat命令未安装"
        fi
    else
        echo "文件不存在"
    fi
}

