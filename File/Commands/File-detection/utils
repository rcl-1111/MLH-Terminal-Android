# 检查文件是否为空
is_empty() {
    local file="$1"
    if [[ -f "$file" ]]; then
        if [[ ! -s "$file" ]]; then
            return 0
        fi
    fi
    return 1
}

# 检查文件是否可读
is_readable() {
    local file="$1"
    if [[ -f "$file" ]] && [[ -r "$file" ]]; then
        return 0
    else
        return 1
    fi
}

# 检查文件是否可写
is_writable() {
    local file="$1"
    if [[ -f "$file" ]] && [[ -w "$file" ]]; then
        return 0
    else
        return 1
    fi
}

