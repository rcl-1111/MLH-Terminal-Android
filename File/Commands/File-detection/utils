# 检查文件是否在病毒库中
check_virus_library() {
    local file="$1"
    local md5_hash="$2"
    local sha1_hash="$3"
    local sha256_hash="$4"
    
    # 跳过空文件哈希（示例文件）
    if [[ "$md5_hash" == "$EMPTY_MD5" ]] || \
       [[ "$sha1_hash" == "$EMPTY_SHA1" ]] || \
       [[ "$sha256_hash" == "$EMPTY_SHA256" ]]; then
        return 0
    fi
    
    local found=false
    
    # 检查各平台病毒库
    for platform in Android Linux Windows MacOS Other; do
        local virus_dir="$VIRUS_LIB_DIR/$platform"
        if [[ -d "$virus_dir" ]]; then
            for json_file in "$virus_dir"/*.json; do
                if [[ -f "$json_file" ]]; then
                    if detect_virus_in_json "$json_file" "$md5_hash" "$sha1_hash" "$sha256_hash"; then
                        found=true
                    fi
                fi
            done
        fi
    done
    
    if [[ "$found" == true ]]; then
        return 1
    else
        return 0
    fi
}

# 在JSON文件中检测病毒
detect_virus_in_json() {
    local json_file="$1"
    local md5_hash="$2"
    local sha1_hash="$3"
    local sha256_hash="$4"
    
    local virus_info=""
    
    # 检查MD5
    if grep -q "\"md5\":\"$md5_hash\"" "$json_file" 2>/dev/null || \
       grep -q "\"md5_hash\":\"$md5_hash\"" "$json_file" 2>/dev/null; then
        virus_info=$(grep -B5 -A5 "\"md5\":\"$md5_hash\"" "$json_file" 2>/dev/null | grep "\"name\":" | head -1 | cut -d'"' -f4)
        if [[ -z "$virus_info" ]]; then
            virus_info="未知病毒"
        fi
        echo -e "${CROSS} 检测到病毒: $virus_info (MD5匹配)"
        return 0
    fi
    
    # 检查SHA1
    if grep -q "\"sha1\":\"$sha1_hash\"" "$json_file" 2>/dev/null || \
       grep -q "\"sha1_hash\":\"$sha1_hash\"" "$json_file" 2>/dev/null; then
        virus_info=$(grep -B5 -A5 "\"sha1\":\"$sha1_hash\"" "$json_file" 2>/dev/null | grep "\"name\":" | head -1 | cut -d'"' -f4)
        if [[ -z "$virus_info" ]]; then
            virus_info="未知病毒"
        fi
        echo -e "${CROSS} 检测到病毒: $virus_info (SHA1匹配)"
        return 0
    fi
    
    # 检查SHA256
    if grep -q "\"sha256\":\"$sha256_hash\"" "$json_file" 2>/dev/null || \
       grep -q "\"sha256_hash\":\"$sha256_hash\"" "$json_file" 2>/dev/null; then
        virus_info=$(grep -B5 -A5 "\"sha256\":\"$sha256_hash\"" "$json_file" 2>/dev/null | grep "\"name\":" | head -1 | cut -d'"' -f4)
        if [[ -z "$virus_info" ]]; then
            virus_info="未知病毒"
        fi
        echo -e "${CROSS} 检测到病毒: $virus_info (SHA256匹配)"
        return 0
    fi
    
    return 1
}

# 检查文件内容中的危险命令
check_dangerous_content() {
    local file="$1"
    local suspicious_count=0
    
    if [[ ! -f "$file" ]]; then
        return 0
    fi
    
    # 只检查文本文件
    if file "$file" 2>/dev/null | grep -q "text"; then
        echo -e "${INFO} 正在扫描文件内容..."
        
        # 检查危险命令
        for pattern in "${DANGEROUS_COMMANDS[@]}"; do
            if grep -iq "$pattern" "$file" 2>/dev/null; then
                echo -e "${WARN} 发现可疑命令: $pattern"
                ((suspicious_count++))
            fi
        done
        
        # 检查危险URL
        for pattern in "${DANGEROUS_URLS[@]}"; do
            if grep -iq "$pattern" "$file" 2>/dev/null; then
                echo -e "${WARN} 发现可疑URL模式: $pattern"
                ((suspicious_count++))
            fi
        done
        
        # 检查危险模式
        for pattern in "${DANGEROUS_PATTERNS[@]}"; do
            if grep -iq "$pattern" "$file" 2>/dev/null; then
                echo -e "${WARN} 发现可疑代码模式: $pattern"
                ((suspicious_count++))
            fi
        done
    fi
    
    if [[ $suspicious_count -gt 0 ]]; then
        echo -e "${WARN} 文件包含 $suspicious_count 个可疑内容"
        return 1
    else
        echo -e "${CHECK} 文件内容未发现明显威胁"
        return 0
    fi
}

# 检查文件扩展名
check_file_extension() {
    local file="$1"
    local extension="${file##*.}"
    extension=$(echo "$extension" | tr '[:upper:]' '[:lower:]')
    
    # 检查可执行文件类型
    for exe_type in "${EXECUTABLE_TYPES[@]}"; do
        if [[ "$extension" == "$exe_type" ]]; then
            echo -e "${WARN} 检测到可执行文件类型: .$extension"
            return 1
        fi
    done
    
    # 检查脚本类型
    for script_type in "${SCRIPT_TYPES[@]}"; do
        if [[ "$extension" == "$script_type" ]]; then
            echo -e "${WARN} 检测到脚本文件类型: .$script_type"
            return 1
        fi
    done
    
    # 检查压缩包类型
    for archive_type in "${ARCHIVE_TYPES[@]}"; do
        if [[ "$extension" == "$archive_type" ]]; then
            echo -e "${WARN} 检测到压缩文件类型: .$archive_type"
            return 1
        fi
    done
    
    return 0
}

